# Git Ignore File for Weather Dashboard Project

# This file specifies intentionally untracked files that Git should ignore.
# It helps keep your repository clean by excluding generated files,
# temporary files, and sensitive information.

# --- Node.js / npm / Yarn ---
# node_modules directory
# This directory contains all your project's dependencies.
# It's generated from package.json and package-lock.json (or yarn.lock)
# and should never be committed to version control.
node_modules/

# npm debug logs
# These are generated by npm for debugging purposes.
npm-debug.log*
.npm/

# Yarn specific files
# Similar to npm-debug.log, these are for Yarn's internal use.
yarn-debug.log*
yarn-error.log*

# Plug'n'Play files (if using Yarn PnP)
.pnp/
.pnp.js

# ESLint cache
# ESLint generates a cache file to speed up linting.
.eslintcache

# --- Build Output ---
# React build directory
# This directory contains the optimized production build of your React app.
# It's generated by `npm run build` (or `yarn build`).
build/

# Other common build/distribution directories (if applicable)
dist/
out/
tmp/

# --- Environment Variables ---
# Local environment variables
# This file contains sensitive API keys and other configuration that
# should not be committed to version control.
# The project context explicitly mentions `.env.local`.
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# --- Operating System Specific Files ---
# macOS specific files
# These are generated by macOS for folder metadata.
.DS_Store

# Windows specific files
# These are generated by Windows for thumbnail caches and desktop settings.
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDE and Editor Specific Files ---
# VS Code specific files
# This directory contains user-specific workspace settings and temporary files.
# While some `.vscode/settings.json` or `.vscode/extensions.json` might be
# useful to commit for team consistency, temporary files should be ignored.
.vscode/*.log
.vscode/*.bak
.vscode/*.code-workspace
.vscode/tasks.json # Often user-specific
.vscode/launch.json # Often user-specific

# IntelliJ / WebStorm specific files
# This directory contains IDE project settings and temporary files.
.idea/

# Sublime Text specific files
*.sublime-project
*.sublime-workspace

# Vim swap files
*.swp
*.swo

# Emacs backup files
*~
\#*#

# --- Test and Coverage Reports ---
# Test coverage reports
# Generated by testing frameworks like Jest.
coverage/

# --- Miscellaneous ---
# Log files
*.log
logs/

# Tarballs (e.g., from `npm pack`)
*.tgz

# Local history files (e.g., from some IDEs)
.history/

# Any other temporary or generated files
*.bak
*.swp
*.swo
*.orig
*.rej